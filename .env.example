# Скопируй этот файл как .env и впиши свои значения.
# Railway → Settings → Variables → DATABASE_URL
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,web-production-dae10.up.railway.app
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,https://web-production-dae10.up.railway.app

# === БАЗА ДАННЫХ ===
# Railway PostgreSQL public URL (Railway Dashboard → PostgreSQL → Variables → DATABASE_PUBLIC_URL)
DATABASE_PUBLIC_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway
DB_SSL_REQUIRE=true

# USE_LOCAL_DB=true  → default БД = SQLite, remote = PostgreSQL (оффлайн-разработка)
# USE_LOCAL_DB=false → default БД = PostgreSQL, local = SQLite (работа с продом)
# По умолчанию false — локальная разработка подключается к Railway PostgreSQL напрямую.
USE_LOCAL_DB=false

DISCORD_WEBHOOK_URL=
